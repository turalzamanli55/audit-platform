# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# EPBSE generated synchronization artifacts
src/lib/project-sync/snapshots/data/sync_*.json
src/lib/project-sync/snapshots/history/

# EDRP runtime-generated artifacts (keep directory structure via .gitkeep)
src/lib/devops/data/artifacts/**
!src/lib/devops/data/artifacts/.gitkeep
src/lib/devops/data/history/**
!src/lib/devops/data/history/.gitkeep
src/lib/devops/data/snapshots/**
!src/lib/devops/data/snapshots/.gitkeep

# EPAC runtime-generated audit artifacts
src/lib/platform-audit/data/snapshots/**
!src/lib/platform-audit/data/snapshots/.gitkeep
src/lib/platform-audit/data/reports/**
!src/lib/platform-audit/data/reports/.gitkeep

# ECIE runtime-generated intelligence artifacts
src/lib/capability-intelligence/data/snapshots/**
!src/lib/capability-intelligence/data/snapshots/.gitkeep
src/lib/capability-intelligence/data/reports/**
!src/lib/capability-intelligence/data/reports/.gitkeep

# EIIE runtime-generated implementation artifacts
src/lib/implementation-intelligence/data/snapshots/**
!src/lib/implementation-intelligence/data/snapshots/.gitkeep
src/lib/implementation-intelligence/data/reports/**
!src/lib/implementation-intelligence/data/reports/.gitkeep

# EPIRE runtime-generated inventory artifacts
src/lib/platform-inventory/data/snapshots/**
!src/lib/platform-inventory/data/snapshots/.gitkeep
src/lib/platform-inventory/data/reports/**
!src/lib/platform-inventory/data/reports/.gitkeep
