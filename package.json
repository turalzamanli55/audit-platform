{
  "name": "audit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "validate:database": "vitest run src/lib/database-governance/database-lifecycle.test.ts src/lib/database-governance/database-governance.test.ts src/lib/sql-foundation/sql-foundation.test.ts",
    "validate:devops": "vitest run src/lib/devops/devops.test.ts && npx tsx scripts/validate-devops.mts",
    "validate:platform-audit": "vitest run src/lib/platform-audit/platform-audit.test.ts && npx tsx scripts/validate-platform-audit.mts",
    "epac:audit": "npx tsx scripts/validate-platform-audit.mts",
    "validate:capability-intelligence": "vitest run src/lib/capability-intelligence/capability-intelligence.test.ts && npx tsx scripts/validate-capability-intelligence.mts",
    "ecie:analyze": "npx tsx scripts/validate-capability-intelligence.mts",
    "validate:implementation-intelligence": "vitest run src/lib/implementation-intelligence/implementation-intelligence.test.ts && npx tsx scripts/validate-implementation-intelligence.mts",
    "eiie:analyze": "npx tsx scripts/validate-implementation-intelligence.mts",
    "validate:platform-inventory": "vitest run src/lib/platform-inventory/platform-inventory.test.ts && npx tsx scripts/validate-platform-inventory.mts",
    "epire:analyze": "npx tsx scripts/validate-platform-inventory.mts",
    "edrp:operate": "npx tsx scripts/edrp-operate.mts",
    "edrp:ci-blueprints": "npx tsx scripts/generate-ci-blueprints.mts",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@google/genai": "^2.11.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "exceljs": "^4.4.0",
    "next": "16.2.9",
    "openai": "^6.46.0",
    "papaparse": "^5.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prettier": "^3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
